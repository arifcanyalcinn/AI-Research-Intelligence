# ============================================================
# ARIP — Environment Variable Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# All variables use the ARIP_ prefix.
# Nested settings use __ as the delimiter.
# Example: ARIP_LOGGING__LEVEL=DEBUG overrides config.logging.level
# ============================================================

# ------------------------------------------------------------
# REQUIRED — Telegram Review Bot
# Required when config.review.enabled = true (the default).
# Create a bot via @BotFather and get the token.
# ------------------------------------------------------------
ARIP_TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ------------------------------------------------------------
# REQUIRED — Twitter/X Publishing
# Required when "twitter" is in config.publishing.publishers.
# Create an app at developer.twitter.com with OAuth 1.0a.
# ------------------------------------------------------------
ARIP_TWITTER_API_KEY=your-api-key
ARIP_TWITTER_API_SECRET=your-api-secret
ARIP_TWITTER_ACCESS_TOKEN=your-access-token
ARIP_TWITTER_ACCESS_SECRET=your-access-secret

# ------------------------------------------------------------
# OPTIONAL — GitHub API Token
# Without this, GitHub Trending source uses unauthenticated
# requests (60 req/hour limit, usually sufficient).
# ------------------------------------------------------------
# ARIP_GITHUB_TOKEN=your-github-token

# ------------------------------------------------------------
# OPTIONAL — Config overrides via environment
# Any config.yaml field can be overridden with ARIP_ prefix.
# ------------------------------------------------------------
# ARIP_LOGGING__LEVEL=DEBUG
# ARIP_PIPELINE__RUN_INTERVAL_HOURS=12
# ARIP_LLM__MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
